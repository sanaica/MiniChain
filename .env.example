# ==================== MiniChain Smart Vault Configuration ====================

# Mode (false = live exchanges, true = mock backtest)
MOCK_MODE=true

# --- Trading Strategy ---
BUY_THRESHOLD_LIVE=0.9995
SELL_THRESHOLD_LIVE=1.0005

# --- Risk Management ---
# Stop-loss: Force sell if price drops 3% below buy price
STOP_LOSS_THRESHOLD=0.97
# Time-stop: Force sell after ~30 minutes in live mode (120 cycles * 15s)
MAX_HOLD_CYCLES=120

# --- Circuit Breaker (Economic Guard) ---
CIRCUIT_MAX_DEVIATION=0.05
CIRCUIT_COOLDOWN=300

# --- Network & Oracle Settings ---
POLL_INTERVAL_MOCK=2
POLL_INTERVAL_LIVE=15
ORACLE_QUORUM=3
ORACLE_TIMEOUT=5